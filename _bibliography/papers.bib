@article{于鑫:1001,
	abbr = {CJP},
	title = {非结构化球谐变换及其在海平面指纹解算中的应用},
	copyright = {http://creativecommons.org/licenses/by/3.0/},
	issn = {0001-5733},
	url = {http://www.geophy.cn/article/doi/10.6038/cjg2026T0634},
	doi = {10.6038/cjg2026T0634},
	abstract = {球谐变换是大地测量学中表述和处理球面函数的基本方法，其可将复杂的球面函数分解为不同频率的正交基函数，便于分析不同空间尺度的地球物理信号，并实现全球范围内的一致表达。地学领域传统球谐变换通常依赖等间隔经纬度格网的均匀采样，结合快速傅里叶变换实现高效计算。然而，对于局部区域问题或信号空间细节特征分布不均的情形，传统方法存在明显局限性：一方面，球谐函数定义于全球且傅里叶变换要求等间隔采样，导致格网划分须保持全球均匀分布，从而在高纬度地区产生格网单元面积与形状畸变，并在研究区域问题时引起数据冗余；另一方面，在对局部区域信号进行球谐变换时，边界处易出现频谱泄露现象。基于自由布置采样点的非结构化格网及非均匀球面傅里叶变换的球谐变换方法具有更强的灵活性和适用性。本文将该方法应用于海平面方程求解，以格陵兰和南极冰盖质量变化引起的全球海平面变化为例，评估其性能。结果表明：该方法能够根据数据特征灵活配置采样点分布，在格陵兰冰盖质量变化趋势的空间模式表达方面具有优势，以较少的采样点实现细节特征描述，同时有效抑制频谱泄露，并将能量集中于感兴趣区域；在海平面指纹计算方面，特别是针对近岸海平面变化梯度较大的区域，模拟实验表明该方法的结果更接近真值。},
	language = {zh},
    year = {2026},
	urldate = {2026-03-03},
	journal = {地球物理学报},
	author = {于鑫 and 孙玉* and 丁智江 and 朱广彬 and 常晓涛},
	preview = {Zhong_etal_2026_CJP.png}
}

